{
  "manifestVersion": 1.0,
  "id": "linked-wiki-pages",
  "version": "0.1.47",
  "name": "Linked Wiki pages",
  "description": "Displays the list of all Wiki pages linked to current Work Item.",
  "publisher": "DimaBors",
  "galleryFlags": [
    "Public",
    "Preview"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services.Cloud"
    }
  ],
  "scopes": [
    "vso.work_write",
    "vso.wiki",
    "vso.code"
  ],
  "icons": {
    "default": "img/icon.png"
  },
  "contributions": [
    {
      "id": "linked-wiki-pages",
      "type": "ms.vss-work-web.work-item-form-group",
      "description": "Displays the list of all Wiki pages linked to current Work Item.",
      "targets": [
        "ms.vss-work-web.work-item-form"
      ],
      "properties": {
        "name": "Linked wiki pages",
        "uri": "linked-wiki-pages.html",
        "height": 200
      }
    },
    {
      "id": "auto-link-scanner-hub",
      "type": "ms.vss-web.hub",
      "description": "Scans wiki pages for work item references (#NNN) and automatically creates links.",
      "targets": [
        "ms.vss-work-web.work-hub-group"
      ],
      "properties": {
        "name": "Wiki Auto-Link Scanner",
        "uri": "auto-link-hub.html",
        "icon": "img/icon.png"
      }
    }
  ],
  "categories": [
    "Azure Boards"
  ],
  "tags": [
    "wiki"
  ],
  "content": {
    "details": {
      "path": "docs/overview.md"
    }
  },
  "links": {
    "repository": {
      "uri": "https://github.com/dimabors/wiki-links-devops"
    },
    "issues": {
      "uri": "https://github.com/dimabors/wiki-links-devops/issues"
    }
  },
  "repository": {
    "type": "git",
    "uri": "https://github.com/dimabors/wiki-links-devops"
  },
  "files": [
    {
      "path": "linked-wiki-pages.html",
      "addressable": true
    },
    {
      "path": "auto-link-hub.html",
      "addressable": true
    },
    {
      "path": "node_modules/vss-web-extension-sdk/lib",
      "addressable": true,
      "packagePath": "vsts"
    },
    {
      "path": "node_modules/knockout/build/output",
      "addressable": true,
      "packagePath": "knockout"
    },
    {
      "path": "js",
      "addressable": true,
      "packagePath": "js"
    },
    {
      "path": "docs/screenshots",
      "addressable": true,
      "packagePath": "screenshots"
    }
  ]
}

